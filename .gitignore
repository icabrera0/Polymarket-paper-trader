# =====================================================
# Polymarket Paper Trading Bot - .gitignore
# =====================================================

# --- Secrets & credentials ---
.env
.env.*
*.key
*.pem
*.secret
*.secrets
*_secret*
*_credentials*
credentials.json
service_account.json

# --- Runtime data (entire directory — all runtime state lives here) ---
# Covers: databases, session tokens, JSON stats, JSONL outcomes, reports, cache
data/

# --- Logs ---
logs/

# --- Reports ---
reports/

# --- Python ---
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.Python
build/
dist/
.installed.cfg

# --- Test & coverage artifacts ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.prof

# --- Type checking / linting caches ---
.mypy_cache/
.ruff_cache/
.pyright/

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- IDEs & editors ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Claude Code & local AI tooling ---
.claude/
.mulch/
.overstory/

# --- Node (if any tooling uses it) ---
node_modules/
package-lock.json
package.json

# --- Context & generated docs (local working notes) ---
CONTEXT.md

# --- OS artifacts ---
.DS_Store
Thumbs.db
desktop.ini

# --- Temporary / backup files ---
*.bak
*.tmp
*.old
*.orig

# --- Archives ---
files/
